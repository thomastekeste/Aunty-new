{
  "expo": {
    "name": "Aunty Curl",
    "slug": "aunty-curl-council",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.auntycurl.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Aunty Curl uses your camera to analyze your hair texture and track progress.",
        "NSPhotoLibraryUsageDescription": "Aunty Curl accesses your photos to analyze your hair and track your journey."
      }
    },
    "android": {
      "package": "com.auntycurl.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0F08"
      }
    },
    "plugins": [
      "expo-font",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "61a03883-cd9d-453e-9145-7584044acd14"
      }
    },
    "owner": "thomastekeste"
  }
}
